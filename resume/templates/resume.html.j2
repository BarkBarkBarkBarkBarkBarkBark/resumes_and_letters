<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ personal.name }} — Resume</title>
  <meta name="description" content="{{ summary_text | trim | truncate(200) }}" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui,
                   Helvetica, Arial, sans-serif;
      font-size: 15px;
      line-height: 1.65;
      color: #1c1c1c;
      background: #e8e8e4;
      padding: 2.5rem 1rem;
      margin: 0;
    }

    .resume {
      max-width: 840px;
      margin: 0 auto;
      background: #fff;
      padding: 3.5rem 4.25rem;
      box-shadow: 0 4px 40px rgba(0, 0, 0, 0.11);
      border-radius: 3px;
    }

    /* ── Header ─────────────────────────────────────────── */
    .resume-header { margin-bottom: 1.75rem; }

    h1 {
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      color: #111;
      margin: 0 0 0.55rem;
    }

    .contact {
      color: #555;
      font-size: 0.875rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0;
    }

    .contact a { color: #1d4ed8; text-decoration: none; }
    .contact a:hover { text-decoration: underline; }
    .sep { color: #ccc; margin: 0 0.45rem; user-select: none; }

    /* ── Section headings ───────────────────────────────── */
    section { margin-top: 2rem; }

    h2 {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.13em;
      color: #111;
      border-bottom: 1.5px solid #d1d1d1;
      padding-bottom: 0.3rem;
      margin: 0 0 1.1rem;
    }

    p { margin: 0 0 0.75rem; font-size: 0.93rem; }

    /* ── Experience / volunteer entries ─────────────────── */
    .entry { margin-bottom: 1.4rem; }

    .entry-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.2rem 0.75rem;
      margin-bottom: 0.2rem;
    }

    .entry-title {
      font-weight: 700;
      font-size: 0.96rem;
      color: #111;
    }

    .entry-dates {
      font-size: 0.84rem;
      color: #666;
      white-space: nowrap;
    }

    .entry-loc {
      font-size: 0.85rem;
      color: #555;
      margin-bottom: 0.35rem;
    }

    ul {
      margin: 0.3rem 0 0 1.3rem;
      padding: 0;
    }

    li {
      margin-bottom: 0.32rem;
      font-size: 0.91rem;
      line-height: 1.55;
    }

    /* ── Education ──────────────────────────────────────── */
    .edu-item { margin-bottom: 0.95rem; }

    .edu-degree {
      font-weight: 700;
      font-size: 0.95rem;
    }

    .edu-gpa {
      font-weight: 400;
      color: #555;
    }

    .edu-detail {
      font-size: 0.875rem;
      color: #555;
      margin-top: 0.1rem;
    }

    /* ── Skills ─────────────────────────────────────────── */
    .skill-group {
      font-size: 0.91rem;
      margin-bottom: 0.42rem;
      line-height: 1.5;
    }

    .skill-cat { font-weight: 700; }

    /* ── Certifications ─────────────────────────────────── */
    .cert-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .cert-list li {
      font-size: 0.91rem;
      padding: 0.15rem 0;
    }

    .cert-list li::before {
      content: "✓\00a0";
      color: #777;
    }

    /* ── Page footer ────────────────────────────────────── */
    .page-footer {
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px solid #ebebeb;
      font-size: 0.78rem;
      color: #aaa;
      text-align: center;
    }

    .page-footer a { color: #aaa; }
    .page-footer a:hover { color: #555; }

    /* ── Print ──────────────────────────────────────────── */
    @media print {
      body { background: white; padding: 0; }
      .resume { box-shadow: none; border-radius: 0; padding: 1rem 1.5rem; }
      .page-footer { display: none; }
    }

    /* ── Mobile ─────────────────────────────────────────── */
    @media (max-width: 620px) {
      .resume { padding: 2rem 1.25rem; }
      h1 { font-size: 1.65rem; }
      .entry-header { flex-direction: column; gap: 0; }
      .entry-dates { white-space: normal; }
    }
  </style>
</head>
<body>
<div class="resume">

  <header class="resume-header">
    <h1>{{ personal.name }}</h1>
    <div class="contact">
      {% set c = personal.contact %}
      <span>{{ c.email }}</span>
      {% if c.phone %}<span class="sep">·</span><span>{{ c.phone }}</span>{% endif %}
      {% if c.location %}<span class="sep">·</span><span>{{ c.location }}</span>{% endif %}
      {% if c.linkedin %}<span class="sep">·</span><a href="https://{{ c.linkedin }}">{{ c.linkedin }}</a>{% endif %}
      {% if c.github %}<span class="sep">·</span><a href="https://{{ c.github }}">{{ c.github }}</a>{% endif %}
      {% if c.website %}<span class="sep">·</span><a href="{{ c.website }}">{{ c.website }}</a>{% endif %}
    </div>
  </header>

  <section>
    <h2>Summary</h2>
    <p>{{ summary_text | trim }}</p>
  </section>

  <section>
    <h2>Experience</h2>
    {% for job in experience %}
    <div class="entry">
      <div class="entry-header">
        <span class="entry-title">{{ job.role }} — {{ job.organization }}</span>
        <span class="entry-dates">{{ job.start_date | fmt_date }} – {{ job.end_date | fmt_date }}</span>
      </div>
      <div class="entry-loc">{{ job.location }}</div>
      <ul>
        {% for bullet in job.bullets %}
        <li>{{ bullet.text | trim }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </section>

  {% if volunteer %}
  <section>
    <h2>Research &amp; Volunteer Experience</h2>
    {% for entry in volunteer %}
    <div class="entry">
      <div class="entry-header">
        <span class="entry-title">{{ entry.role }} — {{ entry.organization }}</span>
        <span class="entry-dates">{{ entry.start_date | fmt_date }} – {{ entry.end_date | fmt_date }}</span>
      </div>
      <div class="entry-loc">{{ entry.location }}</div>
      <ul>
        {% for bullet in entry.bullets %}
        <li>{{ bullet.text | trim }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  <section>
    <h2>Education</h2>
    {% for edu in education %}
    <div class="edu-item">
      <div class="edu-degree">
        {{ edu.degree }}
        {% if edu.gpa %}<span class="edu-gpa"> (GPA: {{ edu.gpa }})</span>{% endif %}
      </div>
      <div class="edu-detail">{{ edu.institution }} · {{ edu.graduation_date }}</div>
    </div>
    {% endfor %}
  </section>

  {% if coursework %}
  <section>
    <h2>Relevant Coursework</h2>
    <ul>
      {% for course in coursework %}
      <li>{{ course }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <section>
    <h2>Skills</h2>
    {% for skill_group in skills %}
    <div class="skill-group">
      <span class="skill-cat">{{ skill_group.category }}:</span>
      {{ skill_group['items'] | join(', ') }}
    </div>
    {% endfor %}
  </section>

  {% if certifications %}
  <section>
    <h2>Certifications</h2>
    <ul class="cert-list">
      {% for cert in certifications %}
      <li>{{ cert.name }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <footer class="page-footer">
    Generated from YAML source · Last updated {{ build_date }}
    {% if personal.contact.github %}
    · <a href="https://{{ personal.contact.github }}">{{ personal.contact.github }}</a>
    {% endif %}
  </footer>

</div>
</body>
</html>
