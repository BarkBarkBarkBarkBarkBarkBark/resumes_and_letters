<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ personal.name }} — Resume</title>
  <meta name="description" content="{{ summary_text | trim | truncate(200) }}" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui,
                   Helvetica, Arial, sans-serif;
      font-size: 15px; line-height: 1.65; color: #1c1c1c;
      background: #e8e8e4; padding: 2.5rem 1rem; margin: 0;
    }
    .tab-bar {
      max-width: 840px; margin: 0 auto;
      display: flex; gap: 0;
      flex-wrap: wrap;
    }
    .tab-btn {
      padding: 0.6rem 1.6rem; font-size: 0.82rem; font-weight: 600;
      letter-spacing: 0.06em; text-transform: uppercase;
      background: #d4d4cf; color: #555; border: none;
      border-radius: 4px 4px 0 0; cursor: pointer;
      transition: background 0.15s, color 0.15s; margin-right: 3px;
    }
    .tab-btn:hover { background: #c8c8c3; color: #222; }
    .tab-btn.active { background: #fff; color: #111; box-shadow: 0 -2px 0 0 #1d4ed8 inset; }
    .card {
      max-width: 840px; margin: 0 auto; background: #fff;
      padding: 3.5rem 4.25rem;
      box-shadow: 0 4px 40px rgba(0,0,0,0.11);
      border-radius: 0 3px 3px 3px;
    }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .resume-header { margin-bottom: 1.75rem; }
    h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -0.025em; color: #111; margin: 0 0 0.55rem; }
    .contact { color: #555; font-size: 0.875rem; display: flex; flex-wrap: wrap; align-items: center; }
    .contact a { color: #1d4ed8; text-decoration: none; }
    .contact a:hover { text-decoration: underline; }
    .hero-links {
      display: flex; flex-wrap: wrap; gap: 0.65rem;
      margin-top: 1rem;
    }
    .hero-btn {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 9rem; padding: 0.7rem 1rem; border-radius: 999px;
      font-size: 0.85rem; font-weight: 700; text-decoration: none;
      border: 1px solid #dbe2f0; color: #1d4ed8; background: #eff6ff;
    }
    .hero-btn.primary {
      background: #1d4ed8; color: #fff; border-color: #1d4ed8;
      box-shadow: 0 8px 18px rgba(29,78,216,0.18);
    }
    .hero-btn:hover { filter: brightness(0.98); }
    .sep { color: #ccc; margin: 0 0.45rem; user-select: none; }
    section { margin-top: 2rem; }
    h2 {
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.13em; color: #111;
      border-bottom: 1.5px solid #d1d1d1; padding-bottom: 0.3rem; margin: 0 0 1.1rem;
    }
    p { margin: 0 0 0.75rem; font-size: 0.93rem; }
    .entry { margin-bottom: 1.4rem; }
    .entry-header {
      display: flex; justify-content: space-between; align-items: baseline;
      flex-wrap: wrap; gap: 0.2rem 0.75rem; margin-bottom: 0.2rem;
    }
    .entry-title { font-weight: 700; font-size: 0.96rem; color: #111; }
    .entry-dates { font-size: 0.84rem; color: #666; white-space: nowrap; }
    .entry-loc { font-size: 0.85rem; color: #555; margin-bottom: 0.35rem; }
    ul { margin: 0.3rem 0 0 1.3rem; padding: 0; }
    li { margin-bottom: 0.32rem; font-size: 0.91rem; line-height: 1.55; }
    .intro-grid {
      display: grid; grid-template-columns: 1.3fr 1fr; gap: 1.4rem;
      align-items: start;
    }
    .intro-card {
      background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 16px;
      padding: 1.15rem 1.1rem;
    }
    .intro-card h3 {
      margin: 0 0 0.6rem; font-size: 0.82rem; text-transform: uppercase;
      letter-spacing: 0.08em; color: #334155;
    }
    .intro-card p:last-child { margin-bottom: 0; }
    .intro-list { margin: 0; padding-left: 1.15rem; }
    .project-summary { margin-top: 0.2rem; }
    .project-summary p:last-child { margin-bottom: 0; }
    .edu-item { margin-bottom: 0.95rem; }
    .edu-degree { font-weight: 700; font-size: 0.95rem; }
    .edu-gpa { font-weight: 400; color: #555; }
    .edu-detail { font-size: 0.875rem; color: #555; margin-top: 0.1rem; }
    .skill-group { font-size: 0.91rem; margin-bottom: 0.42rem; line-height: 1.5; }
    .skill-cat { font-weight: 700; }
    .project-links { margin-top: 0.45rem; font-size: 0.84rem; color: #666; }
    .project-links a { color: #1d4ed8; text-decoration: none; }
    .project-links a:hover { text-decoration: underline; }
    .cert-list { list-style: none; margin: 0; padding: 0; }
    .cert-list li { font-size: 0.91rem; padding: 0.22rem 0; display: flex; align-items: center; gap: 0.6rem; }
    .cert-list li::before { content: ""; }  /* removed — badge replaces checkmark for badged items */
    .cert-badge { height: 52px; width: 52px; object-fit: contain; flex-shrink: 0; }
    .cert-text { display: flex; flex-direction: column; }
    .cert-name { font-weight: 600; }
    .cert-issuer { font-size: 0.82rem; color: #777; }
    .cover-letter p { font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.1rem; }
    .cl-meta { font-size: 0.88rem; color: #666; margin-bottom: 2rem; border-left: 3px solid #1d4ed8; padding-left: 0.75rem; }
    .cl-sign { margin-top: 2rem; font-size: 0.95rem; }
    .page-footer {
      margin-top: 3rem; padding-top: 1rem;
      border-top: 1px solid #ebebeb; font-size: 0.78rem; color: #aaa; text-align: center;
    }
    .page-footer a { color: #aaa; }
    .page-footer a:hover { color: #555; }
    @media print {
      body { background: white; padding: 0; }
      .tab-bar { display: none; }
      .card { box-shadow: none; border-radius: 0; padding: 1rem 1.5rem; }
      .tab-panel { display: block !important; }
      .tab-panel + .tab-panel { page-break-before: always; }
      .page-footer { display: none; }
    }
    @media (max-width: 620px) {
      .card { padding: 2rem 1.25rem; }
      h1 { font-size: 1.65rem; }
      .entry-header { flex-direction: column; gap: 0; }
      .entry-dates { white-space: normal; }
      .intro-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<div class="tab-bar">
  <button class="tab-btn active" onclick="showTab('intro', this)">Intro</button>
  <button class="tab-btn" onclick="showTab('projects', this)">GitHub Projects</button>
  <button class="tab-btn" onclick="showTab('resume', this)">CV</button>
  {% if cover_letter %}
  <button class="tab-btn" onclick="showTab('cover-letter', this)">Letter</button>
  {% endif %}
</div>

<div class="card">

  <!-- ══ INTRO ═══════════════════════════════════════════════════════════════ -->
  <div id="tab-intro" class="tab-panel active">

    <header class="resume-header">
      <h1>{{ personal.name }}</h1>
      <div class="contact">
        {% set c = personal.contact %}
        <span>{{ c.email }}</span>
        {% if c.phone %}<span class="sep">·</span><span>{{ c.phone }}</span>{% endif %}
        {% if c.location %}<span class="sep">·</span><span>{{ c.location }}</span>{% endif %}
        {% if c.github %}<span class="sep">·</span><a href="{{ c.github }}">GitHub portfolio</a>{% endif %}
        {% if c.linkedin %}<span class="sep">·</span><a href="https://{{ c.linkedin }}">{{ c.linkedin }}</a>{% endif %}
      </div>
      <div class="hero-links">
        {% if c.github %}<a class="hero-btn primary" href="{{ c.github }}">View GitHub</a>{% endif %}
        <a class="hero-btn" href="#" onclick="showTab('projects', document.querySelector('[onclick*=&quot;projects&quot;]')); return false;">Browse Projects</a>
        <a class="hero-btn" href="#" onclick="showTab('resume', document.querySelector('[onclick*=&quot;resume&quot;]')); return false;">Open CV</a>
      </div>
    </header>

    <section>
      <h2>{{ site.intro_title if site and site.intro_title else 'About' }}</h2>
      <p>{{ site.intro_blurb if site and site.intro_blurb else summary_text | trim }}</p>
      {% if site and site.seeking %}
      <p>{{ site.seeking }}</p>
      {% endif %}
    </section>

    <section>
      <div class="intro-grid">
        <div class="intro-card">
          <h3>Current interests</h3>
          <ul class="intro-list">
            {% if site and site.interests %}
              {% for item in site.interests %}
              <li>{{ item }}</li>
              {% endfor %}
            {% else %}
              <li>Neural signal processing</li>
              <li>Neurotech tooling</li>
              <li>Spike sorting</li>
            {% endif %}
          </ul>
        </div>
        <div class="intro-card">
          <h3>Quick snapshot</h3>
          <p>Recently admitted to UC Davis Biomedical Engineering.</p>
          <p>Working on single-unit sorting, neural acquisition tooling, and practical open-source neurotech projects.</p>
          {% if c.github %}<p><strong>GitHub:</strong> <a href="{{ c.github }}">{{ c.github }}</a></p>{% endif %}
        </div>
      </div>
    </section>
  </div><!-- /tab-intro -->

  <!-- ══ GITHUB PROJECTS ════════════════════════════════════════════════════ -->
  <div id="tab-projects" class="tab-panel">
    <header class="resume-header">
      <h1>GitHub Projects</h1>
      {% if site and site.github_projects_intro %}
      <p>{{ site.github_projects_intro }}</p>
      {% endif %}
    </header>

    <section>
      <h2>Selected repositories</h2>
      {% for project in projects %}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{ project.name }}</span>
          <span class="entry-dates">{{ project.dates }}</span>
        </div>
        <div class="project-summary">
          {% for bullet in project.bullets %}
          <p>{{ bullet | trim }}</p>
          {% endfor %}
        </div>
        {% if project.links %}
        <div class="project-links">
          {% for link in project.links %}
          <a href="{{ link.url }}">{{ link.label }}</a>{% if not loop.last %} · {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </section>
  </div><!-- /tab-projects -->

  <!-- ══ RESUME ══════════════════════════════════════════════════════════════ -->
  <div id="tab-resume" class="tab-panel">

    <header class="resume-header">
      <h1>{{ personal.name }}</h1>
      <div class="contact">
        {% set c = personal.contact %}
        <span>{{ c.email }}</span>
        {% if c.phone %}<span class="sep">·</span><span>{{ c.phone }}</span>{% endif %}
        {% if c.location %}<span class="sep">·</span><span>{{ c.location }}</span>{% endif %}
        {% if c.github %}<span class="sep">·</span><a href="{{ c.github }}">GitHub portfolio</a>{% endif %}
        {% if c.linkedin %}<span class="sep">·</span><a href="https://{{ c.linkedin }}">{{ c.linkedin }}</a>{% endif %}
        {% if c.website %}<span class="sep">·</span><a href="{{ c.website }}">{{ c.website }}</a>{% endif %}
      </div>
      <div class="hero-links">
        {% if c.github %}<a class="hero-btn primary" href="{{ c.github }}">View GitHub</a>{% endif %}
        {% if c.website %}<a class="hero-btn" href="{{ c.website }}">Portfolio Site</a>{% endif %}
        {% if c.linkedin %}<a class="hero-btn" href="https://{{ c.linkedin }}">LinkedIn</a>{% endif %}
      </div>
    </header>

    <section>
      <h2>Summary</h2>
      <p>{{ summary_text | trim }}</p>
    </section>

    {% if projects %}
    <section>
      <h2>Neuroscience Projects</h2>
      {% for project in projects %}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{ project.name }}</span>
          <span class="entry-dates">{{ project.dates }}</span>
        </div>
        <ul>
          {% for bullet in project.bullets %}
          <li>{{ bullet | trim }}</li>
          {% endfor %}
        </ul>
        {% if project.links %}
        <div class="project-links">
          {% for link in project.links %}
          <a href="{{ link.url }}">{{ link.label }}</a>{% if not loop.last %} · {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </section>
    {% endif %}

    <section>
      <h2>Experience</h2>
      {% for job in experience %}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{ job.role }} — {{ job.organization }}</span>
          <span class="entry-dates">{{ job.start_date | fmt_date }} – {{ job.end_date | fmt_date }}</span>
        </div>
        <div class="entry-loc">{{ job.location }}</div>
        <ul>
          {% for bullet in job.bullets %}
          <li>{{ bullet.text | trim }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </section>

    {% if volunteer %}
    <section>
      <h2>Research &amp; Volunteer Experience</h2>
      {% for entry in volunteer %}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{ entry.role }} — {{ entry.organization }}</span>
          <span class="entry-dates">{{ entry.start_date | fmt_date }} – {{ entry.end_date | fmt_date }}</span>
        </div>
        <div class="entry-loc">{{ entry.location }}</div>
        <ul>
          {% for bullet in entry.bullets %}
          <li>{{ bullet.text | trim }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </section>
    {% endif %}

    <section>
      <h2>Education</h2>
      {% for edu in education %}
      <div class="edu-item">
        <div class="edu-degree">
          {{ edu.degree }}
          {% if edu.gpa %}<span class="edu-gpa"> (GPA: {{ edu.gpa }})</span>{% endif %}
        </div>
        <div class="edu-detail">{{ edu.institution }} · {{ edu.graduation_date }}{% if edu.notes %} · {{ edu.notes }}{% endif %}</div>
      </div>
      {% endfor %}
    </section>

    {% if coursework %}
    <section>
      <h2>Relevant Coursework</h2>
      <ul>
        {% for course in coursework %}
        <li>{{ course }}</li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    <section>
      <h2>Skills</h2>
      {% for skill_group in skills %}
      <div class="skill-group">
        <span class="skill-cat">{{ skill_group.category }}:</span>
        {{ skill_group['items'] | join(', ') }}
      </div>
      {% endfor %}
    </section>

    {% if certifications %}
    <section>
      <h2>Certifications</h2>
      <ul class="cert-list">
        {% for cert in certifications %}
        <li>
          {% if cert.badge_url %}
            {% if cert.credly_url %}<a href="{{ cert.credly_url }}" target="_blank" rel="noopener">{% endif %}
            <img class="cert-badge" src="{{ cert.badge_url }}" alt="{{ cert.name }} badge" />
            {% if cert.credly_url %}</a>{% endif %}
          {% else %}
            <span style="color:#777;font-size:1rem;">&#10003;&nbsp;</span>
          {% endif %}
          <span class="cert-text">
            <span class="cert-name">{{ cert.name }}</span>
            {% if cert.issuer %}<span class="cert-issuer">{{ cert.issuer }}{% if cert.date %} &middot; {{ cert.date }}{% endif %}</span>{% endif %}
          </span>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

  </div><!-- /tab-resume -->

  <!-- ══ COVER LETTER ════════════════════════════════════════════════════════ -->
  {% if cover_letter %}
  <div id="tab-cover-letter" class="tab-panel">
    <div class="cover-letter">

      <header class="resume-header">
        <h1>{{ personal.name }}</h1>
        <div class="contact">
          {% set c = personal.contact %}
          <span>{{ c.email }}</span>
          {% if c.phone %}<span class="sep">·</span><span>{{ c.phone }}</span>{% endif %}
          {% if c.location %}<span class="sep">·</span><span>{{ c.location }}</span>{% endif %}
        </div>
      </header>

      <div class="cl-meta">
        Re: {{ cover_letter.role }} — {{ cover_letter.company }}
      </div>

      {% for para in cover_letter.paragraphs %}
      <p>{{ para | trim }}</p>
      {% endfor %}

      <div class="cl-sign">
        Sincerely,<br><br>
        <strong>{{ personal.name }}</strong>
      </div>

    </div>
  </div><!-- /tab-cover-letter -->
  {% endif %}

  <footer class="page-footer">
    Generated from YAML source · Last updated {{ build_date }}
    {% if personal.contact.github %}
    · <a href="{{ personal.contact.github }}">GitHub</a>
    {% endif %}
  </footer>

</div><!-- /card -->

<script>
  function showTab(name, btn) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
  }
</script>
</body>
</html>
